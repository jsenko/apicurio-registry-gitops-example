{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Money",
  "type": "object",
  "properties": {
    "amount": {
      "type": "number",
      "description": "The monetary amount"
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code",
      "pattern": "^[A-Z]{3}$"
    }
  },
  "required": ["amount", "currency"]
}
